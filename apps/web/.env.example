# RoyalCare Web production environment

# Required: browser-visible API base URL.
NEXT_PUBLIC_API_URL="https://api.example.com/api/v1"

# Backward-compatible alias used by existing clients when NEXT_PUBLIC_API_URL is absent.
NEXT_PUBLIC_ROYALCARE_API_URL="https://api.example.com/api/v1"

# Required for support/renewal/booking WhatsApp actions in the browser.
# Digits only is recommended, with country code handled by app settings where applicable.
NEXT_PUBLIC_ROYALCARE_SUPPORT_WHATSAPP="970599999999"

# Public app URL for deployment checks and future absolute links.
NEXT_PUBLIC_ROYALCARE_APP_URL="https://app.example.com"

