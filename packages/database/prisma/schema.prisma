  createdAt    DateTime @default(now())

  actor  User?   @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  target User?   @relation("AuditLogTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  center Center? @relation(fields: [centerId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([targetUserId])
  @@index([centerId])
  @@index([action])
  @@index([createdAt])
}

model SubscriptionLifecycleJobRun {
  id                            String    @id @default(uuid()) @db.Uuid
  startedAt                     DateTime  @default(now())
  finishedAt                    DateTime?
  triggeredBy                   String    @db.VarChar(80)
  scanned                       Int       @default(0)
  updatedExpired                Int       @default(0)
  notificationsCreated          Int       @default(0)
  auditLogsCreated              Int       @default(0)
  skippedSuspended              Int       @default(0)
  duplicateNotificationsSkipped Int       @default(0)
  success                       Boolean   @default(false)
  errorMessage                  String?

  @@index([startedAt])
  @@index([success])
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

model BookingRequest {
  id            String               @id @default(uuid()) @db.Uuid
  centerId      String               @db.Uuid
  serviceId     String?              @db.Uuid
  offerId       String?              @db.Uuid
  branchId      String?              @db.Uuid
  providerId    String?              @db.Uuid
  appointmentId String?              @unique @db.Uuid
  fullName      String               @db.VarChar(160)
  phone         String               @db.VarChar(32)
  patientArea   String?              @db.VarChar(120)
  notes         String?
  requestedDate DateTime?            @db.Date
  requestedTime String?              @db.VarChar(5)
  source        BookingRequestSource @default(PUBLIC_WEBSITE)
  offerTitle    String?              @db.VarChar(200)
  offerPrice    Decimal?             @db.Decimal(12, 2)
  offerCurrency String?              @db.VarChar(10)
  status        BookingRequestStatus @default(PENDING)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  center      Center        @relation(fields: [centerId], references: [id], onDelete: Cascade)
  service     Service?      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  offer       CenterOffer?  @relation(fields: [offerId], references: [id], onDelete: SetNull)
  branch      CenterBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  provider    User?         @relation("BookingRequestProvider", fields: [providerId], references: [id], onDelete: SetNull)
  appointment Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([centerId, status])
  @@index([centerId, source])
  @@index([centerId, createdAt])
  @@index([centerId, offerId])
  @@index([centerId, branchId])
  @@index([providerId])
  @@index([serviceId])
  @@index([status, createdAt])
}

model PatientPortalToken {
  id        String    @id @default(uuid()) @db.Uuid
  centerId  String    @db.Uuid
  patientId String    @db.Uuid
  token     String    @unique @db.VarChar(64)
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  center  Center  @relation(fields: [centerId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([centerId, patientId])
  @@index([expiresAt])
}

model CenterWorkingHours {
