// RoyalCare Prisma schema.
//
// Phase 1 and Phase 2 foundation:
// - Identity
// - RBAC permissions
// - Centers / tenants
// - Subscriptions
// - Custom domains
// - Customers
// - Services
// - Appointments
// - Sessions
// - Notifications
// - Dynamic pages
// - Branding settings
//
// Tenant-owned models must include centerId unless explicitly documented as
// global platform data.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  INVITED
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

enum RoleStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum PermissionStatus {
  ACTIVE
  INACTIVE
}

enum UserRoleStatus {
  ACTIVE
  INACTIVE
  REVOKED
}

enum RoleScope {
  PLATFORM
  CENTER
  CUSTOMER
}

enum CenterType {
  LASER
  PHYSIOTHERAPY
  HIJAMA
  BEAUTY
  WELLNESS
  MULTI_SPECIALTY
}

enum CenterStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
  ARCHIVED
}

enum SupportedLanguage {
  AR
  HE
  EN
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
  EXPIRED
}

enum BillingInterval {
  MONTHLY
  YEARLY
  CUSTOM
}

enum DomainType {
  CUSTOM
  SUBDOMAIN
}

enum DomainStatus {
  PENDING
  VERIFIED
  ACTIVE
  FAILED
  DISABLED
}

enum SslStatus {
  PENDING
  PROVISIONING
  ACTIVE
  FAILED
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum PatientGender {
  MALE
  FEMALE
  OTHER
  UNKNOWN
}

enum PatientStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ServiceFollowUpMode {
  NONE
  SESSION_BASED_PLAN
  RECURRING_CONTINUOUS
}

enum RecurringIntervalUnit {
  DAY
  WEEK
  MONTH
  YEAR
}

enum PatientFollowUpSourceType {
  APPOINTMENT_COMPLETED
  MANUAL
  BOOKING_REQUEST
}

enum PatientFollowUpStatus {
  DUE
  UPCOMING
  CONTACTED
  BOOKED
  COMPLETED
  MISSED
  CLOSED_EARLY
  CANCELLED
  SKIPPED
  PAUSED
}

enum PatientFollowUpPlanStatus {
  ACTIVE
  COMPLETED
  CLOSED_EARLY
  CANCELLED
  PAUSED
}

enum AppointmentSource {
  ADMIN
  PUBLIC_WEBSITE
  CUSTOMER_PORTAL
  IMPORT
}

enum SessionStatus {
  PLANNED
  COMPLETED
  CANCELLED
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum NotificationTargetAudience {
  SUPER_ADMIN
  CENTER_ADMIN
}

enum NotificationType {
  SUBSCRIPTION_EXPIRING
  SUBSCRIPTION_EXPIRED
  SUBSCRIPTION_RENEWAL_REQUEST
  SUBSCRIPTION_SUSPENDED
  SUBSCRIPTION_RENEWED
  TRIAL_ENDING_SOON
  MISSING_WHATSAPP_PHONE
  BOOKING_REQUEST_CREATED
}

enum DynamicPageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum InvoiceStatus {
  PENDING
  PARTIAL
  PAID
  CANCELLED
}

enum InvoiceSource {
  MANUAL
  AUTO_APPOINTMENT
  AUTO_FOLLOW_UP
  AUTO_RECALCULATION
  AUTO_APPOINTMENT_COMPLETION
}

enum SubscriptionInvoiceStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHECK
  OTHER
}

enum ExpenseStatus {
  PAID
  PENDING
  RECURRING
  CANCELLED
}

enum CreditTransactionType {
  CREDIT_ADD
  CREDIT_USE
}

enum CreditTransactionSource {
  OVERPAYMENT
  MANUAL
  ADJUSTMENT
}

enum BookingRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum PublicBookingMode {
  SIMPLE_REQUEST
  DIRECT_BOOKING
}

enum BookingRequestSource {
  PUBLIC_WEBSITE
  CUSTOMER_PORTAL
  ADMIN
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum MarketingTrackingProvider {
  META_PIXEL
  META_CAPI
  TIKTOK
  GA4
  SNAP
}

enum MarketingTrackingStatus {
  SUCCESS
  FAILED
  SKIPPED
}

enum CenterWebsiteEventType {
  VIEW_CENTER_WEBSITE
  VIEW_BOOKING_PAGE
  CLICK_BOOK_NOW
  CLICK_WHATSAPP
  CLICK_PHONE
  CLICK_MAP
  CLICK_MESSENGER
  VIEW_GALLERY
  VIEW_REVIEWS
  VIEW_BEFORE_AFTER
  VIEW_OFFERS
  SELECT_OFFER
  COMPLETE_BOOKING
  VIEW_CONTACT
  VIEW_SERVICES
  SELECT_SERVICE
}

enum CenterTrafficSource {
  FACEBOOK
  INSTAGRAM
  TIKTOK
  GOOGLE
  DIRECT
  UNKNOWN
}

model User {
  id              String     @id @default(uuid()) @db.Uuid
  email           String?    @unique @db.VarChar(320)
  phone           String?    @unique @db.VarChar(32)
  passwordHash    String?    @db.VarChar(255)
  fullName        String     @db.VarChar(160)
  status          UserStatus @default(INVITED)
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?
  lastLoginAt     DateTime?
  deletedAt       DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  ownedCenters              Center[]               @relation("CenterOwner")
  customers                 Customer[]
  staffAppointments         Appointment[]          @relation("AppointmentStaffUser")
  createdAppointments       Appointment[]          @relation("AppointmentCreatedBy")
  internalNotes             CenterInternalNote[]   @relation("CenterInternalNoteAuthor")
  notifications             Notification[]
  roles                     UserRole[]
  staffInvoices             Invoice[]              @relation("InvoiceStaff")
  paymentsCreated           Payment[]              @relation("PaymentCreatedBy")
  expensesCreated           Expense[]              @relation("ExpenseCreatedBy")
  expenseRecurrencesCreated ExpenseRecurrence[]    @relation("ExpenseRecurrenceCreatedBy")
  creditTransactionsCreated CreditTransaction[]    @relation("CreditTransactionCreatedBy")
  auditLogsAsActor          AuditLog[]             @relation("AuditLogActor")
  auditLogsAsTarget         AuditLog[]             @relation("AuditLogTarget")
  providerWorkingHours      ProviderWorkingHours[] @relation("ProviderWorkingHours")
  providerLeaveDays         ProviderLeaveDay[]     @relation("ProviderLeaveDay")
  bookingRequestsAsProvider BookingRequest[]       @relation("BookingRequestProvider")

  @@index([status])
  @@index([email, status])
  @@index([phone, status])
  @@index([createdAt])
}

model Role {
  id          String     @id @default(uuid()) @db.Uuid
  centerId    String?    @db.Uuid
  key         String     @db.VarChar(120)
  name        String     @db.VarChar(120)
  description String?
  scope       RoleScope
  status      RoleStatus @default(ACTIVE)
  isSystem    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  center      Center?          @relation(fields: [centerId], references: [id], onDelete: Cascade)
  users       UserRole[]
  permissions RolePermission[]

  @@index([centerId])
  @@index([scope, status])
  @@index([key])
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  key         String           @unique @db.VarChar(160)
  name        String           @db.VarChar(140)
  description String?
  scope       RoleScope
  status      PermissionStatus @default(ACTIVE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  roles RolePermission[]

  @@index([scope, status])
}

model UserRole {
  id              String         @id @default(uuid()) @db.Uuid
  userId          String         @db.Uuid
  roleId          String         @db.Uuid
  centerId        String?        @db.Uuid
  status          UserRoleStatus @default(ACTIVE)
  providerEnabled Boolean        @default(false)
  assignedAt      DateTime       @default(now())
  revokedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  center Center? @relation(fields: [centerId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, centerId])
  @@index([userId, status])
  @@index([roleId])
  @@index([centerId, status])
  @@index([centerId, providerEnabled, status])
}

model RolePermission {
  id           String   @id @default(uuid()) @db.Uuid
  roleId       String   @db.Uuid
  permissionId String   @db.Uuid
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
}

model Center {
  id              String            @id @default(uuid()) @db.Uuid
  ownerUserId     String?           @db.Uuid
  name            String            @db.VarChar(160)
  nameAr          String?           @db.VarChar(160)
  nameEn          String?           @db.VarChar(160)
  nameHe          String?           @db.VarChar(160)
  slug            String            @unique @db.VarChar(120)
  type            CenterType
  status          CenterStatus      @default(TRIAL)
  primaryLanguage SupportedLanguage @default(EN)
  timezone        String            @default("Asia/Jerusalem") @db.VarChar(80)
  activatedAt     DateTime?
  suspendedAt     DateTime?
  cancelledAt     DateTime?
  archivedAt      DateTime?
  publicVisible   Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  owner                 User?                    @relation("CenterOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  roles                 Role[]
  userRoles             UserRole[]
  subscriptions         Subscription[]
  subscriptionInvoices  SubscriptionInvoice[]
  domains               Domain[]
  customers             Customer[]
  patients              Patient[]
  services              Service[]
  appointments          Appointment[]
  sessions              Session[]
  notifications         Notification[]
  dynamicPages          DynamicPage[]
  branding              BrandingSettings?
  internalNotes         CenterInternalNote[]
  invoices              Invoice[]
  payments              Payment[]
  expenseCategories     ExpenseCategory[]
  expenses              Expense[]
  expenseRecurrences    ExpenseRecurrence[]
  creditTransactions    CreditTransaction[]
  auditLogs             AuditLog[]
  bookingRequests       BookingRequest[]
  patientPortalTokens   PatientPortalToken[]
  workingHours          CenterWorkingHours[]
  closedDays            CenterClosedDay[]
  providerWorkingHours  ProviderWorkingHours[]
  providerLeaveDays     ProviderLeaveDay[]
  galleryImages         CenterGalleryImage[]
  reviews               CenterReview[]
  beforeAfterItems      CenterBeforeAfter[]
  teamMembers           CenterTeamMember[]
  offers                CenterOffer[]
  branches              CenterBranch[]
  seoSettings           CenterSeoSettings?
  marketingSettings     TenantMarketingSettings?
  marketingTrackingLogs MarketingTrackingLog[]
  websiteEvents         CenterWebsiteEvent[]
  patientFollowUps      PatientFollowUp[]

  @@index([ownerUserId])
  @@index([status])
  @@index([slug, status])
  @@index([type, status])
  @@index([createdAt])
}

model CenterInternalNote {
  id        String   @id @default(uuid()) @db.Uuid
  centerId  String   @db.Uuid
  authorId  String   @db.Uuid
  note      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  center Center @relation(fields: [centerId], references: [id], onDelete: Cascade)
  author User   @relation("CenterInternalNoteAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  @@index([centerId, createdAt])
  @@index([authorId])
  @@index([createdAt])
}

// Platform-level subscription plan definitions.
// planCode/planName on Subscription remain as denormalized strings for
// audit trail and backwards compatibility. planId FK is the v2 source of truth.
model Plan {
  id   String @id @default(uuid()) @db.Uuid
  code String @unique @db.VarChar(80)

  nameEn        String  @db.VarChar(120)
  nameAr        String  @db.VarChar(120)
  nameHe        String  @db.VarChar(120)
  descriptionEn String?
  descriptionAr String?
  descriptionHe String?

  yearlyPrice Decimal @db.Decimal(10, 2)
  currency    String  @default("USD") @db.VarChar(10)

  isActive         Boolean @default(true)
  isPublic         Boolean @default(true)
  isPopular        Boolean @default(false)
  isContactPricing Boolean @default(false)
  displayOrder     Int     @default(0)

  // Stored now, not enforced until Phase 6
  maxUsers                Int?
  maxPatients             Int?
  maxAppointmentsPerMonth Int?

  // [{ key, nameEn, nameAr, nameHe, included }]
  features Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]

  @@index([isActive, isPublic, displayOrder])
}

model Subscription {
  id                   String             @id @default(uuid()) @db.Uuid
  centerId             String             @db.Uuid
  // v2 FK — nullable; existing rows backfilled by plans.seed.ts
  planId               String?            @db.Uuid
  // Keep unchanged: denormalized audit trail + backwards compat
  planCode             String             @db.VarChar(80)
  planName             String             @db.VarChar(120)
  status               SubscriptionStatus @default(TRIALING)
  billingInterval      BillingInterval    @default(MONTHLY)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  nextRenewalDate      DateTime?
  billingNotes         String?
  notificationPhone    String?            @db.VarChar(32)
  notificationLanguage SupportedLanguage?
  trialEndsAt          DateTime?
  expiresAt            DateTime?
  gracePeriodEndsAt    DateTime?
  cancelAt             DateTime?
  cancelledAt          DateTime?
  metadata             Json?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  center   Center                @relation(fields: [centerId], references: [id], onDelete: Restrict)
  plan     Plan?                 @relation(fields: [planId], references: [id], onDelete: SetNull)
  invoices SubscriptionInvoice[]

  @@index([planId])
  @@index([centerId, status])
  @@index([centerId, currentPeriodEnd])
  @@index([status, currentPeriodEnd])
  @@index([expiresAt])
  @@index([gracePeriodEndsAt])
}

model SubscriptionInvoice {
  id             String                    @id @default(uuid()) @db.Uuid
  invoiceNumber  String                    @unique @db.VarChar(80)
  centerId       String                    @db.Uuid
  subscriptionId String                    @db.Uuid
  amount         Decimal                   @db.Decimal(12, 2)
  discount       Decimal                   @default(0) @db.Decimal(12, 2)
  tax            Decimal                   @default(0) @db.Decimal(12, 2)
  total          Decimal                   @db.Decimal(12, 2)
  currency       String                    @default("ILS") @db.VarChar(10)
  status         SubscriptionInvoiceStatus @default(DRAFT)
  paymentMethod  String?                   @db.VarChar(80)
  notes          String?
  issuedAt       DateTime
  dueDate        DateTime
  paidAt         DateTime?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  center       Center       @relation(fields: [centerId], references: [id], onDelete: Restrict)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)

  @@index([centerId])
  @@index([subscriptionId])
  @@index([status, dueDate])
  @@index([centerId, status])
  @@index([issuedAt])
}

model SubscriptionInvoiceNumberCounter {
  year       Int      @id
  nextNumber Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Domain {
  id                String       @id @default(uuid()) @db.Uuid
  centerId          String       @db.Uuid
  hostname          String       @unique @db.VarChar(255)
  type              DomainType
  status            DomainStatus @default(PENDING)
  isPrimary         Boolean      @default(false)
  verificationToken String?      @unique @db.VarChar(160)
  verifiedAt        DateTime?
  activatedAt       DateTime?
  failedAt          DateTime?
  disabledAt        DateTime?
  sslStatus         SslStatus    @default(PENDING)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  center Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  @@index([centerId, status])
  @@index([centerId, isPrimary])
  @@index([status])
}

model Customer {
  id         String             @id @default(uuid()) @db.Uuid
  centerId   String             @db.Uuid
  userId     String?            @db.Uuid
  fullName   String             @db.VarChar(160)
  email      String?            @db.VarChar(320)
  phone      String?            @db.VarChar(32)
  status     CustomerStatus     @default(ACTIVE)
  language   SupportedLanguage?
  notes      String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  archivedAt DateTime?

  center        Center         @relation(fields: [centerId], references: [id], onDelete: Cascade)
  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessions      Session[]
  notifications Notification[]

  @@index([centerId, status])
  @@index([centerId, email])
  @@index([centerId, phone])
  @@index([userId])
  @@index([createdAt])
}

model Patient {
  id            String        @id @default(uuid()) @db.Uuid
  centerId      String        @db.Uuid
  fullName      String        @db.VarChar(160)
  fullNameAr    String?       @db.VarChar(160)
  fullNameHe    String?       @db.VarChar(160)
  fullNameEn    String?       @db.VarChar(160)
  phone         String        @db.VarChar(32)
  email         String?       @db.VarChar(320)
  gender        PatientGender @default(UNKNOWN)
  dateOfBirth   DateTime?
  nationalId    String?       @db.VarChar(80)
  notes         String?
  status        PatientStatus @default(ACTIVE)
  creditBalance Decimal       @default(0) @db.Decimal(12, 2)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  center             Center               @relation(fields: [centerId], references: [id], onDelete: Restrict)
  appointments       Appointment[]
  invoices           Invoice[]
  payments           Payment[]
  creditTransactions CreditTransaction[]
  portalTokens       PatientPortalToken[]
  followUps          PatientFollowUp[]

  @@index([centerId])
  @@index([centerId, status])
  @@index([centerId, phone])
  @@index([centerId, fullName])
  @@index([centerId, createdAt])
}

model Service {
  id                          String                 @id @default(uuid()) @db.Uuid
  centerId                    String                 @db.Uuid
  nameEn                      String                 @default("") @db.VarChar(160)
  nameAr                      String                 @default("") @db.VarChar(160)
  nameHe                      String                 @default("") @db.VarChar(160)
  descriptionEn               String?
  descriptionAr               String?
  descriptionHe               String?
  durationMinutes             Int?
  bufferMinutes               Int                    @default(0)
  followUpEnabled             Boolean                @default(false)
  followUpMode                ServiceFollowUpMode    @default(NONE)
  defaultIntervalDays         Int?
  totalRecommendedSessions    Int?
  recurringIntervalValue      Int?
  recurringIntervalUnit       RecurringIntervalUnit?
  autoWhatsappReminderEnabled Boolean                @default(false)
  autoReminderDaysBefore      Int?
  autoCreateNextReminder      Boolean                @default(true)
  reminderMessageAr           String?
  reminderMessageEn           String?
  reminderMessageHe           String?
  followUpRules               Json?
  price                       Decimal?               @db.Decimal(10, 2)
  currency                    String                 @default("ILS") @db.VarChar(3)
  coverImageUrl               String?                @db.VarChar(800)
  coverImageBlurhash          String?                @db.VarChar(120)
  coverImageAlt               String?                @db.VarChar(200)
  isActive                    Boolean                @default(true)
  createdAt                   DateTime               @default(now())
  updatedAt                   DateTime               @updatedAt
  archivedAt                  DateTime?

  center             Center                     @relation(fields: [centerId], references: [id], onDelete: Cascade)
  appointments       Appointment[]
  sessions           Session[]
  invoices           Invoice[]
  treatmentTemplates ServiceTreatmentTemplate[]
  bookingRequests    BookingRequest[]
  followUps          PatientFollowUp[]

  @@index([centerId])
  @@index([centerId, isActive])
  @@index([centerId, nameEn])
  @@index([centerId, nameAr])
  @@index([centerId, nameHe])
}

model ServiceTreatmentTemplate {
  id                  String   @id @default(uuid()) @db.Uuid
  serviceId           String   @db.Uuid
  nameAr              String   @default("") @db.VarChar(160)
  nameEn              String   @default("") @db.VarChar(160)
  nameHe              String   @default("") @db.VarChar(160)
  totalSessions       Int
  defaultIntervalDays Int?
  phases              Json?
  isDefault           Boolean  @default(false)
  isActive            Boolean  @default(true)
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  service      Service           @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  followUps    PatientFollowUp[]

  @@index([serviceId, isActive, sortOrder])
  @@index([serviceId, isDefault])
}

model Appointment {
  id                                   String            @id @default(uuid()) @db.Uuid
  centerId                             String            @db.Uuid
  patientId                            String            @db.Uuid
  serviceId                            String?           @db.Uuid
  branchId                             String?           @db.Uuid
  staffUserId                          String            @db.Uuid
  createdByUserId                      String            @db.Uuid
  appointmentDate                      DateTime          @db.Date
  startTime                            String            @db.VarChar(5)
  endTime                              String            @db.VarChar(5)
  durationMinutes                      Int
  customServiceName                    String?           @db.VarChar(160)
  customServiceDuration                Int?
  customServicePrice                   Decimal?          @db.Decimal(10, 2)
  customServiceCurrency                String?           @db.VarChar(10)
  customServiceSaved                   Boolean           @default(false)
  status                               AppointmentStatus @default(SCHEDULED)
  notes                                String?
  internalNotes                        String?
  offerTitle                           String?           @db.VarChar(200)
  offerPrice                           Decimal?          @db.Decimal(12, 2)
  offerCurrency                        String?           @db.VarChar(10)
  treatmentTemplateId                  String?           @db.Uuid
  treatmentTemplateNameAr              String?           @db.VarChar(160)
  treatmentTemplateNameEn              String?           @db.VarChar(160)
  treatmentTemplateNameHe              String?           @db.VarChar(160)
  treatmentTemplateTotalSessions       Int?
  treatmentTemplateDefaultIntervalDays Int?
  treatmentTemplatePhases              Json?
  isCancelled                          Boolean           @default(false)
  cancellationReason                   String?
  reminderSent                         Boolean           @default(false)
  lastReminderSentAt                   DateTime?
  reminderCount                        Int               @default(0)
  reminder24hSent                      Boolean           @default(false)
  reminder2hSent                       Boolean           @default(false)
  cancelledAt                          DateTime?
  completedAt                          DateTime?
  createdAt                            DateTime          @default(now())
  updatedAt                            DateTime          @updatedAt

  center            Center                    @relation(fields: [centerId], references: [id], onDelete: Restrict)
  patient           Patient                   @relation(fields: [patientId], references: [id], onDelete: Restrict)
  service           Service?                  @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  branch            CenterBranch?             @relation(fields: [branchId], references: [id], onDelete: SetNull)
  treatmentTemplate ServiceTreatmentTemplate? @relation(fields: [treatmentTemplateId], references: [id], onDelete: SetNull)
  staffUser         User                      @relation("AppointmentStaffUser", fields: [staffUserId], references: [id], onDelete: Restrict)
  createdByUser     User                      @relation("AppointmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  sessions          Session[]
  invoices          Invoice[]
  bookingRequest    BookingRequest?
  followUpsCreated  PatientFollowUp[]         @relation("FollowUpSourceAppointment")
  followUpsNext     PatientFollowUp[]         @relation("FollowUpNextAppointment")

  @@index([centerId, status])
  @@index([centerId, appointmentDate])
  @@index([centerId, staffUserId, appointmentDate])
  @@index([centerId, patientId, appointmentDate])
  @@index([centerId, branchId])
  @@index([serviceId])
  @@index([treatmentTemplateId])
  @@index([createdByUserId])
}

model PatientFollowUp {
  id                      String                    @id @default(uuid()) @db.Uuid
  centerId                String                    @db.Uuid
  patientId               String                    @db.Uuid
  serviceId               String?                   @db.Uuid
  appointmentId           String?                   @db.Uuid
  sourceType              PatientFollowUpSourceType
  title                   String                    @db.VarChar(180)
  notes                   String?
  sessionNumber           Int?
  dueDate                 DateTime                  @db.Date
  isRecurring             Boolean                   @default(false)
  recurringIntervalValue  Int?
