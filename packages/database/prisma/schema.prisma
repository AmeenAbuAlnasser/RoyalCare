// RoyalCare Prisma schema.
//
// Phase 1 and Phase 2 foundation:
// - Identity
// - RBAC permissions
// - Centers / tenants
// - Subscriptions
// - Custom domains
// - Customers
// - Services
// - Appointments
// - Sessions
// - Notifications
// - Dynamic pages
// - Branding settings
//
// Tenant-owned models must include centerId unless explicitly documented as
// global platform data.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  INVITED
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

enum RoleStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum PermissionStatus {
  ACTIVE
  INACTIVE
}

enum UserRoleStatus {
  ACTIVE
  INACTIVE
  REVOKED
}

enum RoleScope {
  PLATFORM
  CENTER
  CUSTOMER
}

enum CenterType {
  LASER
  PHYSIOTHERAPY
  HIJAMA
  BEAUTY
  WELLNESS
  MULTI_SPECIALTY
}

enum CenterStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
  ARCHIVED
}

enum SupportedLanguage {
  AR
  HE
  EN
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
  EXPIRED
}

enum BillingInterval {
  MONTHLY
  YEARLY
  CUSTOM
}

enum DomainType {
  CUSTOM
  SUBDOMAIN
}

enum DomainStatus {
  PENDING
  VERIFIED
  ACTIVE
  FAILED
  DISABLED
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ServiceStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum AppointmentStatus {
  REQUESTED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AppointmentSource {
  ADMIN
  PUBLIC_WEBSITE
  CUSTOMER_PORTAL
  IMPORT
}

enum SessionStatus {
  PLANNED
  COMPLETED
  CANCELLED
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum DynamicPageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id              String     @id @default(uuid()) @db.Uuid
  email           String?    @unique @db.VarChar(320)
  phone           String?    @unique @db.VarChar(32)
  passwordHash    String?    @db.VarChar(255)
  fullName        String     @db.VarChar(160)
  status          UserStatus @default(INVITED)
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?
  lastLoginAt     DateTime?
  deletedAt       DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  ownedCenters  Center[]       @relation("CenterOwner")
  customers     Customer[]
  notifications Notification[]
  roles         UserRole[]

  @@index([status])
  @@index([email, status])
  @@index([phone, status])
  @@index([createdAt])
}

model Role {
  id          String     @id @default(uuid()) @db.Uuid
  centerId    String?    @db.Uuid
  key         String     @db.VarChar(120)
  name        String     @db.VarChar(120)
  description String?
  scope       RoleScope
  status      RoleStatus @default(ACTIVE)
  isSystem    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  center      Center?          @relation(fields: [centerId], references: [id], onDelete: Cascade)
  users       UserRole[]
  permissions RolePermission[]

  @@index([centerId])
  @@index([scope, status])
  @@index([key])
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  key         String           @unique @db.VarChar(160)
  name        String           @db.VarChar(140)
  description String?
  scope       RoleScope
  status      PermissionStatus @default(ACTIVE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  roles RolePermission[]

  @@index([scope, status])
}

model UserRole {
  id         String         @id @default(uuid()) @db.Uuid
  userId     String         @db.Uuid
  roleId     String         @db.Uuid
  centerId   String?        @db.Uuid
  status     UserRoleStatus @default(ACTIVE)
  assignedAt DateTime       @default(now())
  revokedAt  DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  center Center? @relation(fields: [centerId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, centerId])
  @@index([userId, status])
  @@index([roleId])
  @@index([centerId, status])
}

model RolePermission {
  id           String   @id @default(uuid()) @db.Uuid
  roleId       String   @db.Uuid
  permissionId String   @db.Uuid
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
}

model Center {
  id              String            @id @default(uuid()) @db.Uuid
  ownerUserId     String?           @db.Uuid
  name            String            @db.VarChar(160)
  slug            String            @unique @db.VarChar(120)
  type            CenterType
  status          CenterStatus      @default(TRIAL)
  primaryLanguage SupportedLanguage @default(EN)
  timezone        String            @default("Asia/Jerusalem") @db.VarChar(80)
  activatedAt     DateTime?
  suspendedAt     DateTime?
  cancelledAt     DateTime?
  archivedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  owner         User?             @relation("CenterOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  roles         Role[]
  userRoles     UserRole[]
  subscriptions Subscription[]
  domains       Domain[]
  customers     Customer[]
  services      Service[]
  appointments  Appointment[]
  sessions      Session[]
  notifications Notification[]
  dynamicPages  DynamicPage[]
  branding      BrandingSettings?

  @@index([ownerUserId])
  @@index([status])
  @@index([slug, status])
  @@index([type, status])
  @@index([createdAt])
}

model Subscription {
  id                     String             @id @default(uuid()) @db.Uuid
  centerId               String             @db.Uuid
  planCode               String             @db.VarChar(80)
  planName               String             @db.VarChar(120)
  status                 SubscriptionStatus @default(TRIALING)
  billingInterval        BillingInterval    @default(MONTHLY)
  currentPeriodStart     DateTime
  currentPeriodEnd       DateTime
  trialEndsAt            DateTime?
  expiresAt              DateTime?
  cancelAt               DateTime?
  cancelledAt            DateTime?
  externalProvider       String?            @db.VarChar(80)
  externalSubscriptionId String?            @db.VarChar(160)
  metadata               Json?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  center Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  @@index([centerId, status])
  @@index([centerId, currentPeriodEnd])
  @@index([status, currentPeriodEnd])
  @@index([expiresAt])
  @@index([externalProvider, externalSubscriptionId])
}

model Domain {
  id                String       @id @default(uuid()) @db.Uuid
  centerId          String       @db.Uuid
  hostname          String       @unique @db.VarChar(255)
  type              DomainType
  status            DomainStatus @default(PENDING)
  isPrimary         Boolean      @default(false)
  verificationToken String?      @unique @db.VarChar(160)
  verifiedAt        DateTime?
  activatedAt       DateTime?
  failedAt          DateTime?
  disabledAt        DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  center Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  @@index([centerId, status])
  @@index([centerId, isPrimary])
  @@index([status])
}

model Customer {
  id         String             @id @default(uuid()) @db.Uuid
  centerId   String             @db.Uuid
  userId     String?            @db.Uuid
  fullName   String             @db.VarChar(160)
  email      String?            @db.VarChar(320)
  phone      String?            @db.VarChar(32)
  status     CustomerStatus     @default(ACTIVE)
  language   SupportedLanguage?
  notes      String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  archivedAt DateTime?

  center        Center         @relation(fields: [centerId], references: [id], onDelete: Cascade)
  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  appointments  Appointment[]
  sessions      Session[]
  notifications Notification[]

  @@index([centerId, status])
  @@index([centerId, email])
  @@index([centerId, phone])
  @@index([userId])
  @@index([createdAt])
}

model Service {
  id              String        @id @default(uuid()) @db.Uuid
  centerId        String        @db.Uuid
  name            Json
  description     Json?
  category        String?       @db.VarChar(120)
  status          ServiceStatus @default(DRAFT)
  durationMinutes Int?
  price           Decimal?      @db.Decimal(10, 2)
  currency        String?       @db.VarChar(3)
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  archivedAt      DateTime?

  center       Center        @relation(fields: [centerId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  sessions     Session[]

  @@index([centerId, status])
  @@index([centerId, category])
  @@index([centerId, sortOrder])
}

model Appointment {
  id          String             @id @default(uuid()) @db.Uuid
  centerId    String             @db.Uuid
  customerId  String             @db.Uuid
  serviceId   String?            @db.Uuid
  status      AppointmentStatus  @default(REQUESTED)
  source      AppointmentSource  @default(ADMIN)
  startsAt    DateTime
  endsAt      DateTime?
  language    SupportedLanguage?
  notes       String?
  cancelledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  center   Center    @relation(fields: [centerId], references: [id], onDelete: Cascade)
  customer Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service  Service?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  sessions Session[]

  @@index([centerId, status])
  @@index([centerId, startsAt])
  @@index([customerId, startsAt])
  @@index([serviceId])
}

model Session {
  id            String        @id @default(uuid()) @db.Uuid
  centerId      String        @db.Uuid
  customerId    String        @db.Uuid
  appointmentId String?       @db.Uuid
  serviceId     String?       @db.Uuid
  status        SessionStatus @default(PLANNED)
  sessionNumber Int?
  performedAt   DateTime?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  center      Center       @relation(fields: [centerId], references: [id], onDelete: Cascade)
  customer    Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  service     Service?     @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([centerId, status])
  @@index([centerId, performedAt])
  @@index([customerId, performedAt])
  @@index([appointmentId])
  @@index([serviceId])
}

model Notification {
  id              String              @id @default(uuid()) @db.Uuid
  centerId        String              @db.Uuid
  customerId      String?             @db.Uuid
  recipientUserId String?             @db.Uuid
  channel         NotificationChannel
  status          NotificationStatus  @default(PENDING)
  eventKey        String              @db.VarChar(120)
  language        SupportedLanguage   @default(EN)
  title           Json?
  body            Json?
  recipientEmail  String?             @db.VarChar(320)
  recipientPhone  String?             @db.VarChar(32)
  sentAt          DateTime?
  failedAt        DateTime?
  failureReason   String?
  metadata        Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  center        Center    @relation(fields: [centerId], references: [id], onDelete: Cascade)
  customer      Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  recipientUser User?     @relation(fields: [recipientUserId], references: [id], onDelete: SetNull)

  @@index([centerId, status])
  @@index([centerId, eventKey])
  @@index([customerId])
  @@index([recipientUserId])
  @@index([createdAt])
}

model DynamicPage {
  id             String            @id @default(uuid()) @db.Uuid
  centerId       String            @db.Uuid
  slug           String            @db.VarChar(160)
  title          Json
  content        Json
  status         DynamicPageStatus @default(DRAFT)
  seoTitle       Json?
  seoDescription Json?
  publishedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  archivedAt     DateTime?

  center Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  @@unique([centerId, slug])
  @@index([centerId, status])
  @@index([publishedAt])
}

model BrandingSettings {
  id               String            @id @default(uuid()) @db.Uuid
  centerId         String            @unique @db.Uuid
  logoUrl          String?           @db.VarChar(500)
  primaryColor     String?           @db.VarChar(20)
  secondaryColor   String?           @db.VarChar(20)
  accentColor      String?           @db.VarChar(20)
  defaultLanguage  SupportedLanguage @default(EN)
  enabledLanguages Json
  theme            Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  center Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  @@index([defaultLanguage])
}
