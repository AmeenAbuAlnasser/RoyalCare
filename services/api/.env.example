# RoyalCare API production environment

# Required: PostgreSQL connection string used by Prisma and the API process.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/royalcare?schema=public"

# Required in production: strong random secret for signed Center Admin sessions.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ROYALCARE_CENTER_SESSION_SECRET=""

# Optional: API listen port. Defaults to 3001.
PORT=3001

# Required for PDF invoice generation when Chromium is not discoverable automatically.
# Windows example: C:\Program Files\Google\Chrome\Application\chrome.exe
# Linux example: /usr/bin/chromium-browser
CHROME_PATH=""

# Public app/API URLs used by deployment, callbacks, and operational checks.
ROYALCARE_API_URL="https://api.example.com/api/v1"
ROYALCARE_WEB_URL="https://app.example.com"
ROYALCARE_PUBLIC_URL="https://www.example.com"

# Platform/Super Admin auth integration.
# Current local implementation uses x-royalcare-super-admin-user-id internally.
# If an edge/auth proxy is used, configure it to set and protect that header.
ROYALCARE_PLATFORM_AUTH_HEADER="x-royalcare-super-admin-user-id"
ROYALCARE_JWT_SECRET=""

# WhatsApp: manual mode opens wa.me links. API mode is reserved for WhatsApp Business API.
WHATSAPP_MODE="manual"
WHATSAPP_API_URL=""
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_ID=""

# Optional: Meta Graph API version used for server-side Conversion API events.
# Tenant-specific pixel IDs and conversion tokens are stored per center in Tenant Marketing Settings.
META_GRAPH_API_VERSION="v20.0"
